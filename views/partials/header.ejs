<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Miss Poet Collection 📜</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Playfair+Display:ital,wght@0,400;0,600&display=swap"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: 'EB Garamond', serif;
        background-color: #fdfcf7;
        color: #2a2421;
      }
      .aesthetic-header {
        background-color: #fcfbfa;
        border-bottom: 1px solid rgba(112, 83, 53, 0.1);
        letter-spacing: 2px;
      }
      .brand-title {
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        letter-spacing: 4px;
        color: #1a1512;
        text-transform: uppercase;
      }
      .journal-wrapper {
        display: flex;
        min-height: calc(100vh - 75px);
      }
      .sidebar-panel {
        width: 270px;
        background-color: #f8f6f0;
        border-right: 1px solid rgba(112, 83, 53, 0.08);
        padding: 2rem 1.2rem;
        position: sticky;
        top: 75px;
        height: calc(100vh - 75px);
        overflow-y: auto;
      }
      .sidebar-panel::-webkit-scrollbar {
        width: 3px;
      }
      .sidebar-panel::-webkit-scrollbar-thumb {
        background: rgba(112, 83, 53, 0.1);
      }

      .main-canvas {
        flex-grow: 1;
        padding: 0;
      }
      .dynamic-banner {
        height: 250px;
        background-size: cover;
        background-position: center;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 0 2000px rgba(26, 21, 18, 0.45);
        transition: all 0.4s ease-in-out;
        margin-bottom: 2.5rem;
      }
      .banner-text {
        font-family: 'Playfair Display', serif;
        color: #fdfcf7;
        font-size: 2.3rem;
        letter-spacing: 4px;
        text-transform: uppercase;
      }
      .nav-vibe-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .nav-vibe-link {
        color: #6e5d53;
        text-decoration: none;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 4px;
        transition: all 0.2s;
      }
      .nav-vibe-link:hover,
      .nav-vibe-link.active {
        background-color: #f1ede2;
        color: #1a1512;
        transform: translateX(4px);
        font-weight: 500;
      }
      .poem-card {
        background: #fdfcf7;
        border: none;
        border-bottom: 1px solid rgba(112, 83, 53, 0.1);
        padding: 2rem 1rem;
        margin-bottom: 1rem;
        transition: all 0.3s;
      }
      .poem-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        color: #1a1512;
      }
      .poem-body {
        font-size: 1.25rem;
        line-height: 1.8;
        color: #3a322d;
        white-space: pre-line;
      }
      .poem-img-card {
        max-width: 480px;
        background: #fff;
        padding: 12px 12px 24px 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.05);
        margin: 1.5rem auto;
      }
      @media (max-width: 768px) {
        .journal-wrapper {
          flex-direction: column;
        }
        .sidebar-panel {
          width: 100%;
          height: auto;
          position: relative;
          top: 0;
        }
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg aesthetic-header sticky-top py-3">
      <div class="container-fluid px-4">
        <a class="navbar-brand brand-title" href="/">Miss Poet Collection</a>
        <div
          class="d-flex gap-4 ms-auto text-uppercase small"
          style="letter-spacing: 1.5px; font-size: 0.8rem"
        >
          <a href="/" class="text-decoration-none text-dark fw-medium">Home</a>
          <a
            href="/dashboard"
            class="text-decoration-none text-muted hover-dark"
            >✒️ Creator's Desk</a
          >
        </div>
      </div>
    </nav>

    <div class="journal-wrapper">
      <aside class="sidebar-panel">
        <h6
          class="text-uppercase tracking-wider text-muted small mb-3"
          style="letter-spacing: 2px"
        >
          Poem Themes
        </h6>
        <ul class="nav-vibe-list d-flex flex-column gap-1">
          <li>
            <a
              href="/"
              class="nav-vibe-link <%= activeCategory === 'latest' ? 'active' : '' %>"
              >✨ All Collections</a
            >
          </li>
          <% categories.forEach(function(cat) { %>
          <li>
            <a
              href="/?category=<%= cat.id %>"
              class="nav-vibe-link <%= activeCategory === cat.id ? 'active' : '' %>"
            >
              <%= cat.name %>
            </a>
          </li>
          <% }); %>
        </ul>
      </aside>

      <main class="main-canvas">
        <div
          class="dynamic-banner"
          style="background-image: url('<%= themeBanner %>')"
        >
          <h1 class="banner-text text-center px-3"><%= themeName %></h1>
        </div>

        <div class="container px-4 px-md-5 pb-5">
          <div class="row justify-content-center">
            <div class="col-lg-9">
              <% if (poems.length === 0) { %>
              <div class="text-center py-5 text-muted">
                <p class="fs-4 italic">
                  This chapter is empty. No verses crafted here yet.
                </p>
              </div>
              <% } else { %>
              <% poems.forEach(function(poem) { %>
              <article class="poem-card text-center">
                <h2 class="poem-title mb-1"><%= poem.title %></h2>
                <p class="text-muted small italic mb-4">
                  Dated: <%= poem.date %>
                </p>

                <% if (poem.image) { %>
                <div class="poem-img-card">
                  <img
                    src="<%= poem.image %>"
                    class="img-fluid rounded-1"
                    alt="Poetry Snapshot"
                  />
                  <p class="text-muted small mt-3 mb-0 italic">
                    <%= poem.body %>
                  </p>
                </div>
                <% } else { %>
                <div class="poem-body mx-auto my-4" style="max-width: 600px">
                  <%= poem.body %>
                </div>
                <% } %>
              </article>
              <% }); %>
              <% } %>
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
