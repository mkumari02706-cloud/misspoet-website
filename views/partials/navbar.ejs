<aside class="sidebar-panel">
  <div
    class="text-uppercase text-muted small fw-bold mb-3 px-2"
    style="letter-spacing: 1.5px; font-size: 0.7rem; opacity: 0.8"
  >
    Poem Themes
  </div>
  <ul class="nav-vibe-list d-flex flex-column gap-1">
    <li>
      <a
        href="/?category=all"
        class="nav-vibe-link <%= activeCategory === 'all' ? 'active' : '' %>"
      >
        ✨ All Collections
      </a>
    </li>
    <% categories.forEach(cat => { %>
    <li>
      <a
        href="/?category=<%= cat.id %>"
        class="nav-vibe-link <%= activeCategory === cat.id ? 'active' : '' %>"
      >
        🖋️ <%= cat.name %>
      </a>
    </li>
    <% }) %>
  </ul>
</aside>

<main class="main-canvas"></main>
