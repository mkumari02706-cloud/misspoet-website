<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container my-5" style="max-width: 600px">
  <div class="mb-4">
    <a href="/dashboard" class="classic-link">← Back to Desk</a>
  </div>

  <h2 class="fw-normal mb-4 text-center">Edit Your Verse</h2>

  <form action="/update/<%= poem.id %>" method="POST" class="mt-4" enctype="multipart/form-data">

    <div class="mb-4">
      <label class="text-uppercase text-muted small tracking-widest d-block mb-1"
        style="font-size: 0.75rem">Title of the Verse</label>
      <input
        type="text"
        name="title"
        class="form-control classic-input"
        value="<%= poem.title %>"
        required
      />
    </div>

    <div class="mb-4">
      <label class="text-uppercase text-muted small tracking-widest d-block mb-1"
        style="font-size: 0.75rem">Category / Mood</label>
      <select name="category" class="form-control classic-input">
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= poem.category === cat.id ? 'selected' : '' %>>
            <%= cat.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="mb-4">
      <label class="text-uppercase text-muted small tracking-widest d-block mb-2"
        style="font-size: 0.75rem">Pour your heart out</label>
      <textarea
        name="body"
        rows="10"
        class="form-control"
        style="
          border: 1px solid rgba(112, 83, 53, 0.15);
          background-color: #fffdf9;
          border-radius: 4px;
          font-family: 'Playfair Display', serif;
          font-style: italic;
          padding: 15px;
          font-size: 1.1rem;
          line-height: 1.8;
          color: #3d352e;
        "
        required
      ><%= poem.body %></textarea>
    </div>

    <div class="text-center mt-5">
      <button
        type="submit"
        class="btn btn-dark rounded-0 px-5 py-2 text-uppercase small"
        style="letter-spacing: 2px; background-color: #2c2520"
      >
        Save Changes
      </button>
      <a href="/dashboard" class="btn btn-outline-secondary rounded-0 px-4 py-2 ms-3 text-uppercase small"
        style="letter-spacing: 2px">
        Cancel
      </a>
    </div>

  </form>
</div>

<%- include('partials/footer') %>