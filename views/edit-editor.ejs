<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm p-4" style="border-radius: 16px">
        <h2 class="mb-4 text-center">✏️ Edit Your Masterpiece</h2>

        <!-- Form POST request bhejega naye route par -->
        <form action="/update-poem/<%= poem.id %>" method="POST">
          <div class="mb-3">
            <label for="title" class="form-label fw-bold">Poem Title</label>
            <input
              type="text"
              class="form-control"
              id="title"
              name="title"
              value="<%= poem.title %>"
              required
            />
          </div>

          <div class="mb-3">
            <label for="category" class="form-label fw-bold">Category</label>
            <input
              type="text"
              class="form-control"
              id="category"
              name="category"
              value="<%= poem.category %>"
              required
            />
          </div>

          <div class="mb-3">
            <label for="body" class="form-label fw-bold">Poem Body</label>
            <textarea
              class="form-control"
              id="body"
              name="body"
              rows="8"
              required
            >
<%= poem.body %></textarea
            >
          </div>

          <div class="d-grid gap-2">
            <button type="submit" class="btn btn-warning btn-lg fw-bold">
              Save Changes ✨
            </button>
            <a href="/dashboard" class="btn btn-light">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
