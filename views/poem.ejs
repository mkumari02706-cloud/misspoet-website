<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= poem.title %> | Miss Poet Collection 📜</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Playfair+Display:ital,wght@0,400;0,600&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'EB Garamond', serif;
        background-color: #fdfcf7;
        color: #2a2421;
      }
      .aesthetic-header {
        background-color: #fcfbfa;
        border-bottom: 1px solid rgba(112, 83, 53, 0.1);
      }
      .brand-title {
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        letter-spacing: 4px;
        color: #1a1512;
        text-transform: uppercase;
        text-decoration: none;
      }
      .dynamic-banner {
        height: 220px;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 0 2000px rgba(26, 21, 18, 0.45);
        margin-bottom: 3rem;
      }
      .banner-text {
        font-family: 'Playfair Display', serif;
        color: #fdfcf7;
        font-size: 2rem;
        letter-spacing: 4px;
        text-transform: uppercase;
      }
      .poem-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        color: #1a1512;
      }
      .poem-body {
        font-size: 1.3rem;
        line-height: 2;
        color: #3a322d;
        white-space: pre-line;
      }
      .poem-img-card {
        max-width: 500px;
        background: #fff;
        padding: 12px 12px 24px 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.05);
        margin: 2rem auto;
      }
      .back-link {
        color: #6e5d53;
        text-decoration: none;
        font-size: 0.95rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: all 0.2s;
      }
      .back-link:hover {
        color: #1a1512;
      }
      .divider {
        border: none;
        border-top: 1px solid rgba(112, 83, 53, 0.15);
        margin: 2rem auto;
        max-width: 200px;
      }
      footer {
        background-color: #f8f6f0;
        border-top: 1px solid rgba(112, 83, 53, 0.1);
        padding: 2rem;
        text-align: center;
        color: #9e8e84;
        font-size: 0.9rem;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg aesthetic-header sticky-top py-3">
      <div class="container-fluid px-4">
        <a class="navbar-brand brand-title" href="/">Miss Poet Collection</a>
        <div
          class="d-flex gap-4 ms-auto text-uppercase small"
          style="letter-spacing: 1.5px; font-size: 0.8rem"
        >
          <a href="/" class="text-decoration-none text-dark fw-medium">Home</a>
          <a href="/dashboard" class="text-decoration-none text-muted"
            >✒️ Spill Ink</a
          >
        </div>
      </div>
    </nav>

    <!-- BANNER -->
    <div
      class="dynamic-banner"
      style="background-image: url('<%= themeBanner %>')"
    >
      <h1 class="banner-text text-center px-3"><%= poem.title %></h1>
    </div>

    <!-- POEM CONTENT -->
    <div class="container px-4 pb-5" style="max-width: 750px">
      <div class="mb-4">
        <a href="/" class="back-link">← Back to Collection</a>
      </div>

      <article class="text-center">
        <h1 class="poem-title mb-2"><%= poem.title %></h1>
        <p
          class="text-muted small mb-5"
          style="font-style: italic; letter-spacing: 1px"
        >
          Dated: <%= poem.date %> &nbsp;|&nbsp; <%= poem.category %>
        </p>

        <hr class="divider" />

        <% if (poem.image) { %>
        <div class="poem-img-card">
          <img
            src="<%= poem.image %>"
            class="img-fluid"
            alt="Poetry Snapshot"
          />
          <p class="text-muted small mt-3 mb-0" style="font-style: italic">
            <%= poem.body %>
          </p>
        </div>
        <% } else { %>
        <div class="poem-body mx-auto my-4" style="max-width: 600px">
          <%= poem.body %>
        </div>
        <% } %>

        <hr class="divider" />

        <!-- ACTION BUTTONS -->
        <div class="d-flex justify-content-center gap-3 mt-4">
          <a
            href="/edit/<%= poem.id %>"
            class="btn btn-outline-dark rounded-0 px-4 py-2 text-uppercase small"
            style="letter-spacing: 2px"
          >
            ✏️ Edit
          </a>
          <form
            action="/delete/<%= poem.id %>"
            method="POST"
            onsubmit="return confirm('Delete this verse forever?');"
          >
            <button
              type="submit"
              class="btn btn-outline-danger rounded-0 px-4 py-2 text-uppercase small"
              style="letter-spacing: 2px"
            >
              🗑️ Delete
            </button>
          </form>
        </div>
      </article>
    </div>

    <!-- FOOTER -->
    <footer>
      <p class="mb-0">Miss Poet Collection &mdash; Every word, a world. ✨</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
